{
  "name": "car-color-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram bot for car color selection and AI repaint previews",
  "bin": {
    "import-catalog": "./dist/cli/importCatalog.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "import-catalog": "tsx src/cli/importCatalog.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "pdfjs-dist": "^4.10.38",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
